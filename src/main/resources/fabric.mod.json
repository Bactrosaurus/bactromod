{
  "schemaVersion": 1,
  "id": "bactromod",
  "version": "${version}",
  "name": "BactroMod",
  "description": "A lightweight mod with some game optimizations and features.",
  "authors": ["Bactrosaurus"],
  "contributors": ["FurnyGo", "Libreh"],
  "contact": {
    "issues": "https://github.com/Bactrosaurus/bactromod/issues",
    "sources": "https://github.com/Bactrosaurus/bactromod",
    "homepage": "https://modrinth.com/mod/bactromod"
  },
  "environment": "client",
  "license": "LGPL-3.0-only",
  "icon": "assets/bactromod/icon.png",
  "entrypoints": {
    "client": [
      "de.daniel.bactromod.BactroMod::init"
    ],
    "modmenu": [
      "de.daniel.bactromod.impl.ModMenuIntegration"
    ]
  },
  "mixins": [
    "bactromod.mixins.json"
  ],
  "accessWidener" : "bactromod.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}